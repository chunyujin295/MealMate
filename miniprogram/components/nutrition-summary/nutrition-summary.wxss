.nutrition-summary {
  padding: 20rpx 24rpx;
  text-align: center;
}

.calories-row {
  margin-bottom: 12rpx;
}

.calories-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.calories-unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.macro-row {
  padding: 0 30rpx;
  margin-bottom: 8rpx;
}

.macro-item {
  text-align: center;
}

.macro-value {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
}

.macro-label {
  font-size: 20rpx;
  color: var(--text-hint);
}
