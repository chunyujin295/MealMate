.meal-picker {
  display: flex;
  gap: 16rpx;
}

.meal-option {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border: 3rpx solid var(--border);
  border-radius: 14rpx;
  transition: all 0.2s;
  background: var(--white);
}

.meal-option.selected {
  border-color: var(--primary);
  background: var(--primary-light);
}

.meal-option .meal-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.meal-option .meal-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.meal-option.selected .meal-label {
  color: var(--primary-dark);
  font-weight: 600;
}
