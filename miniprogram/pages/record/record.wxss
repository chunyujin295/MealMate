.date-picker {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
}

.char-count {
  margin-top: 8rpx;
  font-size: 22rpx;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 156rpx;
  height: 156rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.image-add {
  width: 156rpx;
  height: 156rpx;
  border: 3rpx dashed var(--border);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-hint);
}

.add-icon {
  font-size: 48rpx;
  color: var(--border);
  line-height: 1;
}

.add-text {
  font-size: 20rpx;
  margin-top: 6rpx;
}

/* AI 相关 */
.ai-btn {
  padding: 24rpx;
  border-radius: 12rpx;
}

.ai-hint {
  font-size: 22rpx;
}

.ai-result-item {
  padding: 16rpx;
  background: var(--bg);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
}

.ai-result-item:active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.ai-nutri-preview {
  flex-wrap: wrap;
}

/* 营养数据 */
.nutrition-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.nutrition-field {
  width: calc(50% - 8rpx);
}

.nutrition-field-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.nutrition-input-row {
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  overflow: hidden;
  background: var(--white);
}

.nutrition-input {
  flex: 1;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  text-align: right;
}

.nutrition-unit {
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: var(--text-hint);
  background: var(--bg);
}

/* 可见权限 */
.visibility-options {
  gap: 16rpx;
}

.visibility-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}

.visibility-option.active {
  border-color: var(--primary);
  background: var(--primary-light);
  color: var(--primary-dark);
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 30rpx;
}

.action-buttons > view {
  text-align: center;
  padding: 24rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
}
