/* 视图切换 */
.view-toggle {
  padding: 12rpx;
}

.toggle-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.toggle-item.active {
  background: var(--primary);
  color: white;
}

/* 日历 */
.calendar-header {
  padding: 20rpx 10rpx;
}

.month-text {
  font-size: 32rpx;
  font-weight: 600;
}

.nav-arrow {
  font-size: 48rpx;
  padding: 10rpx 24rpx;
  color: var(--primary);
}

.weekday-header {
  padding: 0 4rpx;
}

.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 12rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--white);
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.day-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  border-bottom: 1rpx solid #f5f5f5;
  border-right: 1rpx solid #f5f5f5;
}

.day-cell:nth-child(7n) {
  border-right: none;
}

.day-cell.empty {
  background: #fafafa;
}

.day-cell.today .day-num {
  background: var(--primary);
  color: white;
  border-radius: 50%;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

.day-num {
  font-size: 28rpx;
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-top: 6rpx;
}

.selected-date-section {
  margin-top: 20rpx;
}

/* 列表视图 */
.filter-bar {
  gap: 16rpx;
  flex-wrap: wrap;
}

.filter-tag {
  padding: 10rpx 20rpx;
  background: var(--white);
  border-radius: 20rpx;
  font-size: 24rpx;
  box-shadow: var(--shadow);
}

.meal-icon-sm {
  margin-right: 10rpx;
}

.list-images {
  gap: 10rpx;
}

.list-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.load-more {
  padding: 30rpx;
  font-size: 26rpx;
}
