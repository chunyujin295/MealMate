.date-bar {
  text-align: center;
  padding: 20rpx 24rpx;
}

.date-nav {
  padding: 10rpx 20rpx;
}

.arrow {
  font-size: 48rpx;
  color: var(--primary);
  font-weight: 300;
}

.date-display {
  position: relative;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
}

.weekday-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.today-badge {
  position: absolute;
  top: -8rpx;
  right: -50rpx;
  background: var(--primary);
  color: white;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

/* 营养摘要 */
.nutrition-bar {
  text-align: center;
  padding: 28rpx;
}

.calories-main {
  margin-bottom: 16rpx;
}

.calories-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
}

.calories-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.macro-row {
  padding: 0 40rpx;
  margin-bottom: 12rpx;
}

.macro-item {
  text-align: center;
}

.macro-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
}

.macro-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
}

.nutrition-detail-link {
  font-size: 24rpx;
  color: var(--primary);
}

/* 餐次区域 */
.meal-section {
  margin-bottom: 28rpx;
}

.meal-header {
  padding: 16rpx 8rpx;
}

.meal-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.meal-label {
  font-size: 30rpx;
  font-weight: 600;
}

.meal-count {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
}

.add-btn {
  color: var(--primary);
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid var(--primary);
  border-radius: 20rpx;
}

.empty-meal {
  padding: 30rpx;
  text-align: center;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* 记录项 */
.record-item {
  padding: 20rpx 24rpx;
}

.record-content {
  width: 100%;
}

.record-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.record-thumb image {
  width: 100%;
  height: 100%;
}

.record-text {
  font-size: 28rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.record-tags {
  margin-top: 6rpx;
}

.record-time {
  font-size: 22rpx;
  margin-top: 6rpx;
}

.record-arrow {
  color: var(--text-hint);
  font-size: 36rpx;
  margin-left: 10rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

.add-first-btn {
  padding: 20rpx 60rpx;
}
