page {
  --primary: #4CAF50;
  --primary-dark: #388E3C;
  --primary-light: #C8E6C9;
  --danger: #f44336;
  --warning: #FF9800;
  --text: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #e0e0e0;
  --bg: #f5f5f5;
  --white: #ffffff;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text);
  background-color: var(--bg);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

/* 按钮样式 */
.btn-primary {
  background: var(--primary);
  color: var(--white);
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-outline {
  background: var(--white);
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  padding: 18rpx 38rpx;
  font-size: 28rpx;
}

.btn-danger {
  background: var(--danger);
  color: var(--white);
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

.btn-small {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

/* 表单项 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 22rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--white);
}

.form-textarea {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  min-height: 160rpx;
  background: var(--white);
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 文字样式 */
.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 34rpx; }
.text-bold { font-weight: 600; }
.text-center { text-align: center; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.p-20 { padding: 20rpx; }

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.tag-green {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.tag-orange {
  background: #FFF3E0;
  color: #E65100;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-hint);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 移除 button 原生边框 */
button::after {
  border: none;
}
